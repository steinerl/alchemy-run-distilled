{
  "description": "Add missing 404 responses observed from the live API",
  "patches": [
    {
      "op": "add",
      "path": "/paths/~1v1~1projects~1{projectId}~1databases/post/responses/404",
      "value": {
        "description": "Project not found",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "hint": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "code",
                    "message"
                  ]
                }
              },
              "required": [
                "error"
              ]
            }
          }
        }
      }
    }
  ]
}
