{
  "name": "@distilled.cloud/aws",
  "version": "0.16.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/alchemy-run/distilled",
    "directory": "packages/aws"
  },
  "type": "module",
  "sideEffects": false,
  "module": "src/index.ts",
  "files": [
    "lib",
    "src"
  ],
  "exports": {
    "./*": {
      "types": "./lib/services/*.d.ts",
      "bun": "./src/services/*.ts",
      "default": "./lib/services/*.js"
    },
    "./Auth": {
      "types": "./lib/auth.d.ts",
      "bun": "./src/auth.ts",
      "default": "./lib/auth.js"
    },
    "./Category": {
      "types": "./lib/category.d.ts",
      "bun": "./src/category.ts",
      "default": "./lib/category.js"
    },
    "./Credentials": {
      "types": "./lib/credentials.d.ts",
      "bun": "./src/credentials.ts",
      "default": "./lib/credentials.js"
    },
    "./Errors": {
      "types": "./lib/errors.d.ts",
      "bun": "./src/errors.ts",
      "default": "./lib/errors.js"
    },
    "./Region": {
      "types": "./lib/region.d.ts",
      "bun": "./src/region.ts",
      "default": "./lib/region.js"
    },
    "./Retry": {
      "types": "./lib/retry.d.ts",
      "bun": "./src/retry.ts",
      "default": "./lib/retry.js"
    },
    "./Sensitive": {
      "types": "./lib/sensitive.d.ts",
      "bun": "./src/sensitive.ts",
      "default": "./lib/sensitive.js"
    },
    "./Traits": {
      "types": "./lib/traits.d.ts",
      "bun": "./src/traits.ts",
      "default": "./lib/traits.js"
    },
    ".": {
      "types": "./lib/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsgo",
    "build": "tsgo -b",
    "fmt": "oxfmt --write src",
    "lint": "oxlint --fix src",
    "check": "tsgo && oxlint src && oxfmt --check src",
    "test": "bunx vitest run test --exclude specs --passWithNoTests",
    "publish:npm": "bun run build && bun publish --access public",
    "generate": "bun run scripts/generate.ts && oxlint --fix src && oxfmt --write src && oxfmt --write src",
    "specs:fetch": "git submodule update --force --init --recursive --depth=1 specs/api-models-aws && git -C specs/api-models-aws checkout -- . && git submodule update --force --init --recursive --depth=1 specs/aws-sdk-js-v3 && git -C specs/aws-sdk-js-v3 checkout -- . && git submodule update --force --init --recursive --depth=1 specs/smithy && git -C specs/smithy checkout -- . && git submodule update --force --init --recursive --depth=1 specs/smithy-typescript && git -C specs/smithy-typescript checkout -- .",
    "specs:update": "git -C specs/api-models-aws fetch && git -C specs/api-models-aws checkout main && git -C specs/api-models-aws pull && git -C specs/aws-sdk-js-v3 fetch && git -C specs/aws-sdk-js-v3 checkout main && git -C specs/aws-sdk-js-v3 pull && git -C specs/smithy fetch && git -C specs/smithy checkout main && git -C specs/smithy pull && git -C specs/smithy-typescript fetch && git -C specs/smithy-typescript checkout main && git -C specs/smithy-typescript pull"
  },
  "dependencies": {
    "@aws-crypto/crc32": "catalog:",
    "@aws-crypto/util": "catalog:",
    "@aws-sdk/credential-providers": "catalog:",
    "@aws-sdk/types": "catalog:",
    "@distilled.cloud/core": "workspace:*",
    "@smithy/shared-ini-file-loader": "catalog:",
    "@smithy/types": "catalog:",
    "@smithy/util-base64": "catalog:",
    "aws4fetch": "catalog:",
    "effect": "catalog:",
    "fast-xml-parser": "catalog:"
  },
  "devDependencies": {
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "archiver": "catalog:",
    "dedent": "catalog:",
    "dotenv": "catalog:",
    "pathe": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
